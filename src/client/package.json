{
  "name": "gearlist-client",
  "version": "1.0.0",
  "description": "gearlist.studio SPA frontend",
  "private": true,
  "scripts": {
    "prebuild:host": "mkdir -p ../server/Host/wwwroot/assets",
    "build:host:js": "esbuild src/index.jsx --bundle --outfile=../server/Host/wwwroot/assets/app.js --format=esm --sourcemap",
    "build:host:css": "sass src/styles/main.scss ../server/Host/wwwroot/assets/app.raw.css --no-source-map && postcss ../server/Host/wwwroot/assets/app.raw.css -o ../server/Host/wwwroot/assets/app.css && rm -f ../server/Host/wwwroot/assets/app.raw.css",
    "build:host": "npm run build:host:js && npm run build:host:css && cp index.html ../server/Host/wwwroot/index.html",
    "prebuild": "mkdir -p ../../dist/client/assets",
    "build:js": "esbuild src/index.jsx --bundle --outfile=../../dist/client/assets/app.js --format=esm --sourcemap",
    "build:css": "sass src/styles/main.scss ../../dist/client/assets/app.raw.css --no-source-map && postcss ../../dist/client/assets/app.raw.css -o ../../dist/client/assets/app.css",
    "build": "npm run build:js && npm run build:css && cp index.html ../../dist/client/index.html",
    "watch:js": "esbuild src/index.jsx --bundle --outfile=../../dist/client/assets/app.js --format=esm --sourcemap --watch",
    "watch:css": "sass --watch src/styles/main.scss:../../dist/client/assets/app.raw.css --no-source-map",
    "watch:postcss": "postcss ../../dist/client/assets/app.raw.css -o ../../dist/client/assets/app.css --watch",
    "dev": "npm run build"
  },
  "keywords": [
    "react",
    "esbuild",
    "scss",
    "postcss"
  ],
  "author": "",
  "license": "UNLICENSED",
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.27",
    "esbuild": "^0.27.3",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "sass": "^1.98.0"
  }
}
