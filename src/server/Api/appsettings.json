{
  "MongoDb": {
    "ConnectionString": "mongodb://localhost:27017",
    "DatabaseName": "gearlist",
    "UsersCollectionName": "users"
  },
  "Jwt": {
    "Issuer": "gearlist.studio",
    "Audience": "gearlist.studio.client",
    "Key": "replace-with-a-long-random-secret-at-least-32-characters",
    "ExpiresMinutes": 120
  },
  "LettuceEncrypt": {
    "AcceptTermsOfService": true,
    "DomainNames": [
      "gearlist.studio"
    ],
    "EmailAddress": "admin@gearlist.studio"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
